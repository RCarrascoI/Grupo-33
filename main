import sys
import csv
from typing import List, Dict, Set

class Tarea:
    def __init__(self, id_tarea: str, duracion: int, categoria: str):
        self.id = id_tarea
        self.duracion = duracion
        self.categoria = categoria
class Recurso:
    def __init__(self, id_recurso: str, categorias: Set[str]):
        self.id = id_recurso
        self.categorias = categorias
        self.tiempo_disponible = 0  

class Asignacion:
    def __init__(self, id_tarea: str, id_recurso: str, inicio: int, fin: int):
        self.id_tarea = id_tarea
        self.id_recurso = id_recurso
        self.inicio = inicio
        self.fin = fin 

def leer_tareas(ruta_archivo: str) -> List[Tarea]:
    tareas = []
    with open(ruta_archivo, mode='r', encoding='utf-8') as archivo:
        lector_csv = csv.reader(archivo)
        for fila in lector_csv:
            if fila: 
                id_tarea = fila[0].strip()
                duracion = int(fila[1].strip())
                categoria = fila[2].strip()
                tareas.append(Tarea(id_tarea, duracion, categoria))
    return tareas 

def leer_recursos(ruta_archivo: str) -> List[Recurso]:
    recursos = []
    with open(ruta_archivo, mode='r', encoding='utf-8') as archivo:
        lector_csv = csv.reader(archivo)
        for fila in lector_csv:
            if fila:
                id_recurso = fila[0].strip()
               
                categorias = {cat.strip() for cat in fila[1:]}
                recursos.append(Recurso(id_recurso, categorias))
    return recursos

def planificar_tareas(tareas: List[Tarea], recursos: List[Recurso]) -> List[Asignacion]:
   
    tareas_ordenadas = sorted(tareas, key=lambda t: t.duracion, reverse=True)
    asignaciones: List[Asignacion] = []

   
    for tarea in tareas_ordenadas:
        
        recursos_compatibles = [r for r in recursos if tarea.categoria in r.categorias]
        
        if not recursos_compatibles:
            print(f"Error: Ningún recurso es compatible con la tarea {tarea.id}")
            sys.exit(1)

        
        mejor_recurso = min(recursos_compatibles, key=lambda r: r.tiempo_disponible)

        
        inicio = mejor_recurso.tiempo_disponible
        fin = inicio + tarea.duracion
        
       
        asignaciones.append(Asignacion(tarea.id, mejor_recurso.id, inicio, fin))
        
       
        mejor_recurso.tiempo_disponible = fin

    return asignaciones

def guardar_output(asignaciones: List[Asignacion], ruta_archivo: str) -> None:
    with open(ruta_archivo, mode='w', encoding='utf-8', newline='') as archivo:
        escritor_csv = csv.writer(archivo)
        for asig in asignaciones:
            escritor_csv.writerow([asig.id_tarea, asig.id_recurso, asig.inicio, asig.fin]) 